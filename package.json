{
  "name": "error-sound-notifier",
  "displayName": "Error Sound Notifier",
  "description": "Plays a sound when an error occurs in VS Code",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ggauravky/error-sound-notifier"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "errorSoundNotifier.enable",
        "title": "Error Sound: Enable"
      },
      {
        "command": "errorSoundNotifier.disable",
        "title": "Error Sound: Disable"
      },
      {
        "command": "errorSoundNotifier.testSound",
        "title": "Error Sound: Test Sound"
      },
      {
        "command": "errorSoundNotifier.toggle",
        "title": "Error Sound: Toggle Status"
      }
    ],
    "configuration": {
      "title": "Error Sound Notifier",
      "properties": {
        "errorSoundNotifier.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable error sounds globally"
        },
        "errorSoundNotifier.listenToTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Listen for errors in terminal output"
        },
        "errorSoundNotifier.listenToDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Listen for errors in editor diagnostics"
        },
        "errorSoundNotifier.volume": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "Output volume (0-100)"
        },
        "errorSoundNotifier.cooldownMs": {
          "type": "number",
          "default": 3000,
          "description": "Cooldown in milliseconds between sounds to prevent spam"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.86.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "sound-play": "^1.1.0"
  }
}